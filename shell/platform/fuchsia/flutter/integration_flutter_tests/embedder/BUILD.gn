assert(is_fuchsia)

import("//build/fuchsia/sdk.gni")
import("$fuchsia_sdk_path/build/test.gni")

group("tests") {
  testonly = true
  deps = [
    ":flutter_embedder_test",
  ]
}

fuchsia_test("flutter_embedder_test") {
  testonly = true

  deps = [ ":flutter_embedder_test_lib" ]

  manifest = "meta/flutter_embedder_test.cmx"

  data_deps = [
    "//flutter/shell/platform/fuchsia/flutter/integration_flutter_tests/embedder/child-view",
    "//flutter/shell/platform/fuchsia/flutter/integration_flutter_tests/embedder/parent-view",
  ]
}

static_library("flutter_embedder_test_lib") {
  testonly = true

  output_name = "flutter_embedder_test"

  sources = [
    "flutter-embedder-test.cc",
    "flutter-embedder-test.h",
  ]

  libs = [
    # This is needed for //third_party/googletest for linking zircon symbols.
    "//fuchsia/sdk/$host_os/arch/$target_cpu/sysroot/lib/libzircon.so",
  ]

  include_dirs = [
    "//flutter/shell/platform/fuchsia/flutter/integration_flutter_tests/fuchsia_testing",
  ]

  public_deps = [
    "//third_party/googletest:gtest",
  ]

  deps = [
    "$fuchsia_sdk_root/fidl:fuchsia.sys",
    "$fuchsia_sdk_root/fidl:fuchsia.ui.app",
    "$fuchsia_sdk_root/fidl:fuchsia.ui.input",
    "$fuchsia_sdk_root/fidl:fuchsia.ui.policy",
    "$fuchsia_sdk_root/fidl:fuchsia.ui.scenic",
    "$fuchsia_sdk_root/pkg:fit",
    "$fuchsia_sdk_root/pkg:sys_cpp",
    "$fuchsia_sdk_root/pkg:sys_cpp_testing",
    "//flutter/shell/platform/fuchsia/flutter/integration_flutter_tests/fuchsia_testing/lib/sys/cpp/testing:integration",
    "//flutter/shell/platform/fuchsia/flutter/integration_flutter_tests/fuchsia_testing/src/lib/ui/base_view",
    "$fuchsia_sdk_root/pkg:scenic_cpp",
    "//third_party/googletest:gtest_main",
    "//flutter/shell/platform/fuchsia/flutter/integration_flutter_tests/fuchsia_testing/src/ui/testing/views",
    "$fuchsia_sdk_root/pkg:zx",
    "$fuchsia_sdk_root/pkg:async-loop-cpp",
    "$fuchsia_sdk_root/pkg:async-loop-default",
  ]
}
