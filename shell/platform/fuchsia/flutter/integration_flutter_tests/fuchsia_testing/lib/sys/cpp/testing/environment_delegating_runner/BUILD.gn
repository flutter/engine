import("//build/fuchsia/sdk.gni")
import("//flutter/tools/fuchsia/fuchsia_archive.gni")

fuchsia_archive("environment_delegating_runner") {
  testonly = true

  deps = [ ":bin" ]

  binary = "$target_name"

  meta_dir = "//flutter/shell/platform/fuchsia/flutter/integration_flutter_tests/fuchsia_testing/lib/sys/cpp/testing/environment_delegating_runner/meta"

  meta = [
    {
      path = rebase_path("meta/$target_name.cmx")
      dest = "$target_name.cmx"
    },
  ]
}

executable("bin") {
  output_name = "environment_delegating_runner"
  testonly = true

  sources = [ "environment_delegating_runner.cc" ]

  libs = [
    # This is needed for //third_party/googletest for linking zircon symbols.
    "//fuchsia/sdk/$host_os/arch/$target_cpu/sysroot/lib/libzircon.so",
  ]

  deps = [
    "$fuchsia_sdk_root/fidl:fuchsia.sys",
    "$fuchsia_sdk_root/pkg:fidl_cpp",
    "$fuchsia_sdk_root/pkg:sys_cpp",
    "$fuchsia_sdk_root/pkg:async-loop-cpp",
    "$fuchsia_sdk_root/pkg:async-loop-default",
    "$fuchsia_sdk_root/pkg:zx",
  ]
}
