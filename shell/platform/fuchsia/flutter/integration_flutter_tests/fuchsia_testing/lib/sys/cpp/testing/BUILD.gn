import("//build/fuchsia/sdk.gni")

source_set("integration") {
  testonly = true

  sources = [
    "test_with_environment.cc",
    "test_with_environment.h",
  ]

  public_deps = [
    ":enclosing_environment",
    ":realm_builder",
    "//flutter/shell/platform/fuchsia/flutter/integration_flutter_tests/fuchsia_testing/lib/gtest",
  ]

  include_dirs = [
    "//flutter/shell/platform/fuchsia/flutter/integration_flutter_tests/fuchsia_testing",
  ]
}

source_set("enclosing_environment") {
  testonly = true

  sources = [
    "component_interceptor.cc",
    "component_interceptor.h",
    "enclosing_environment.cc",
    "enclosing_environment.h",
    "launcher_impl.cc",
    "launcher_impl.h",
  ]

  deps = [
    # fuchsia.debugdata FIDL is not in the SDK
    # "$fuchsia_sdk_root/fidl:fuchsia.debugdata",
    "environment_delegating_runner:bin",
    "//third_party/rapidjson",
  ]

  include_dirs = [
    "//flutter/shell/platform/fuchsia/flutter/integration_flutter_tests/fuchsia_testing",
  ]

  public_deps = [
    "$fuchsia_sdk_root/fidl:fuchsia.sys",
    "$fuchsia_sdk_root/pkg:fidl_cpp",
    "$fuchsia_sdk_root/pkg:sys_cpp",
    "$fuchsia_sdk_root/pkg:vfs_cpp",
  ]
}

# Temporarily house RealmBuiler in its own source_set until it's ready to
# be published in SDK. When the library is ready for public consumption, it'll
# be moved to the "unit" package above.
source_set("realm_builder") {
  testonly = true

  sources = [
    "realm_builder.cc",
    "realm_builder.h",
  ]

  public_deps = [
    # This is needed to ensure that realm_builder.h header is found by .cc ???
    "$fuchsia_sdk_root/pkg:sys_cpp",
  ]

  include_dirs = [
    "//flutter/shell/platform/fuchsia/flutter/integration_flutter_tests/fuchsia_testing",
  ]
}
