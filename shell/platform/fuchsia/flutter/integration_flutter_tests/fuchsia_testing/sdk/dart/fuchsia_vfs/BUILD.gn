import("//build/fuchsia/sdk.gni")

import("//flutter/tools/fuchsia/dart/dart_library.gni")

dart_library("fuchsia_vfs") {
  package_name = "fuchsia_vfs"
  null_safe = true

  sources = [
    "src/composed_pseudo_dir.dart",
    "src/internal/_error_node.dart",
    "src/internal/_flags.dart",
    "src/pseudo_dir.dart",
    "src/pseudo_file.dart",
    "src/pseudo_vmo_file.dart",
    "src/service.dart",
    "src/vmo_file.dart",
    "src/vnode.dart",
    "vfs.dart",
  ]

  deps = [
    "//flutter/shell/platform/fuchsia/flutter/integration_flutter_tests/fuchsia_testing/sdk/dart/fidl",
    "//flutter/shell/platform/fuchsia/flutter/integration_flutter_tests/fuchsia_testing/sdk/dart/zircon",
    "//flutter/tools/fuchsia/fidl:fuchsia.io",
    "//flutter/tools/fuchsia/fidl:fuchsia.io2",
    "//third_party/dart/pkg/meta",
    "//third_party/pkg/quiver",
  ]
}
